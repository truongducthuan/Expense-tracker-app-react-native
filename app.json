{
  "expo": {
    "name": "Manage Expense",
    "slug": "expense-stracker-app",
    "owner": "thuantd",
    "scheme": "expensetracker",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/pig.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/pig.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1.0.0",
      "bundleIdentifier": "com.thuanthien.expensestrackerapp",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/pig.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.thuanthien.expensestrackerapp",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7db209aa-666c-4107-90c3-7e2ad38fbebd"
      }
    }
  }
}
